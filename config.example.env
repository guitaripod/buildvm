# buildvm config — copy to ~/.config/buildvm/config.env and fill in. NEVER commit the real file.
# Every value can also be exported directly in the environment; the file is just convenience.

# --- App Store Connect API key (for altool upload) ---
export BUILDVM_ASC_KEY_ID=XXXXXXXXXX
export BUILDVM_ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export BUILDVM_ASC_KEY_P8=$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8

# --- Signing ---
export BUILDVM_TEAM=XXXXXXXXXX                              # Apple Developer team id
export BUILDVM_DIST_P12=$HOME/secrets/distribution.p12      # Apple Distribution cert + key
export BUILDVM_DIST_P12_PASSWORD_FILE=$HOME/secrets/distribution.p12.password
# ...or inline instead of a file:
# export BUILDVM_DIST_P12_PASSWORD='the-password'
export BUILDVM_SIGNING_IDENTITY='Apple Distribution'        # matches the p12's cert
export BUILDVM_SIGNING_DIR=$HOME/secrets/profiles           # dir --profile names resolve against

# --- Host / VM ---
# export BUILDVM_SSH_PUBKEY=$HOME/.ssh/id_ed25519.pub       # installed into the guest
# export BUILDVM_TART=$HOME/.local/bin/tart                 # tart binary (auto-detected on PATH)
# export BUILDVM_NAME=buildvm                               # VM name
# export BUILDVM_BASE=ghcr.io/cirruslabs/macos-tahoe-base:latest   # stable-macOS base image
# export BUILDVM_USER=admin                                 # guest user (cirruslabs images: admin/admin)
# export BUILDVM_PASS=admin

# macOS (Mac App Store) builds: the Mac Installer Distribution certificate used to
# sign the exported .pkg. Password defaults to the dist p12 password when unset.
# export BUILDVM_MAC_INSTALLER_P12=/path/to/mac_installer.p12
# export BUILDVM_MAC_INSTALLER_P12_PASSWORD_FILE=/path/to/password
# export BUILDVM_MAC_INSTALLER_IDENTITY="Mac Installer Distribution"
